# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SERVER_HOST=0.0.0.0
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medcare_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-64-byte-hex-secret
JWT_REFRESH_SECRET=change-me-to-another-64-byte-hex-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Criptografia de campos sigilosos (CPF, CNPJ, PHI) ──────
# 32 bytes em hex (64 caracteres) — gerar com: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-key-aes-256-gcm-0000000000000000
# Pepper para blind index (busca por CPF/CNPJ sem decriptar) — gerar com: openssl rand -hex 32
BLIND_INDEX_PEPPER=change-me-to-a-random-pepper-for-hmac-lookup-0000000000000000

# ── Storage (MinIO / S3-compatible) ─────────────────────────
STORAGE_DRIVER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=medcare
MINIO_SECRET_KEY=medcare123456
MINIO_BUCKET=medcare-files
# Em S3 real (STORAGE_DRIVER=s3), precisa bater com a região do bucket —
# senão a AWS rejeita a autodetecção de região do SDK minio.
MINIO_REGION=us-east-1

# ── App ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
CORS_ORIGIN=http://localhost:5173
MEDICAL_ACCESS_CODE_TTL_MINUTES=15
MEDICAL_ACCESS_TEMPORARY_GRANT_DAYS=30
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_SESSION_EXPIRES_IN=5m
PASSWORD_RESET_MAX_REQUESTS_PER_HOUR=5
FAMILY_MEMBER_ACTIVATION_TOKEN_EXPIRES_IN=3d
FAMILY_MEMBER_ACTIVATION_LINK_BASE_URL=https://lp.medcaresw.com/reset-password
DOCTOR_ACTIVATION_LINK_BASE_URL=http://localhost:5173/reset-password

# ── SMTP (e-mail transacional — esqueci a senha, convite de cuidador) ────────
# Opcionais: sem eles, o e-mail só é logado no console (ver src/shared/mail).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=medcare@medcaresw.com
SMTP_FROM_NAME=Medcare

# ── Retention / LGPD ─────────────────────────────────────────
AUDIT_RETENTION_DAYS=365
SOFT_DELETE_RETENTION_DAYS=90

# ── IA de visão (extração de dados do medicamento a partir de foto) ──────────
# Opcional: sem a chave, o endpoint de scan retorna AI_EXTRACTION_FAILED em vez
# de derrubar o servidor (ver src/modules/medication-scan).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ── Integração Gmail (OAuth — conectar/desconectar conta, Fase 1) ────────────
# Opcionais: sem credenciais, os endpoints de /integrations/gmail retornam erro
# controlado em vez de derrubar o servidor (ver src/modules/gmail-integration).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Deve ser a URL pública real da API (Railway) e a mesma URI no Google Cloud Console.
# api.medcaresw.com só funciona se o DNS apontar para o Railway — senão NXDOMAIN no callback.
GOOGLE_OAUTH_REDIRECT_URI=https://api-medcare-production.up.railway.app/api/v1/integrations/gmail/oauth-callback
GOOGLE_OAUTH_APP_RETURN_SCHEME=appmedcare://gmail-oauth-callback

# Ops Gmail (fora do código):
# 1) Railway: confirmar GOOGLE_OAUTH_REDIRECT_URI = URL acima (ou DNS api.medcaresw.com → Railway).
# 2) Google Cloud Console → Credentials → Authorized redirect URIs = mesma URI.
# 3) OAuth consent screen: Publishing status = Production (ou adicionar cada e-mail em Test users).
#    Em Testing só test users (ex. souzanatha04@gmail.com) conseguem autorizar.

# ── Integração App Store Connect (relatório de downloads — Fase 7.2) ────────
# Opcionais: sem credenciais, o job diário de sincronização pula o iOS e loga um
# aviso em vez de derrubar o servidor (ver src/modules/store-analytics).
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Conteúdo do arquivo .p8 gerado no App Store Connect — nunca commitar o valor real.
APP_STORE_CONNECT_PRIVATE_KEY=
APP_STORE_CONNECT_VENDOR_NUMBER=
APP_STORE_CONNECT_APP_ID=6786394968

# ── Integração Google Play (relatório de downloads — Fase 7.2) ──────────────
# Opcionais: sem credenciais, o job diário de sincronização pula o Android e
# loga um aviso em vez de derrubar o servidor (ver src/modules/store-analytics).
# JSON completo da service account (Play Developer Reporting API) como string
# de uma linha — nunca commitar o valor real.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=

{
  "name": "api-medcare",
  "version": "0.1.0",
  "description": "Backend compartilhado (app-medcare + web-medcare) — prontuário eletrônico familiar, portal médico/clínica/admin",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "start": "prisma migrate deploy && node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "script:soft-delete-user": "tsx scripts/soft-delete-user-by-email.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.2",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.1.0",
    "google-auth-library": "^10.9.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "nanoid": "^5.1.5",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pino-pretty": "^13.1.3",
    "ua-parser-js": "^2.0.10",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@vitest/coverage-v8": "^3.0.8",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  }
}

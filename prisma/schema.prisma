generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  PATIENT_ADMIN // admin familiar (app-medcare)
  FAMILY_MEMBER // membro da família com acesso restrito aos próprios dados
  CAREGIVER // cuidador, acessa múltiplas famílias via código
  DOCTOR // médico, login por CRM (web-medcare)
  CLINIC_ADMIN // administrador de clínica (web-medcare)
  PLATFORM_ADMIN // administrador da plataforma (web-medcare)
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum BiologicalSex {
  MALE
  FEMALE
}

enum MedicationForm {
  TABLET
  CAPSULE
  DROPS
  INJECTION
  SYRUP
  OINTMENT
  PATCH
  OTHER
}

enum DoseState {
  TAKEN
  LATE
  MISSED
}

enum MedicationStripeColor {
  BLACK
  RED
  ORANGE
  NONE
}

enum VaccineStatus {
  UP_TO_DATE
  BOOSTER_DUE
}

enum ExamSource {
  GMAIL
  DOCTOR
  MANUAL
}

enum ProcedureStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AccessStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
}

enum AccessValidity {
  PERMANENT
  TEMPORARY
}

enum PlanType {
  CLINIC
  DOCTOR
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum PaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
  TRANSFER
}

enum SubscriptionStatus {
  ACTIVE
  LATE
  CANCELLED
}

enum SupplierCategory {
  INFRASTRUCTURE
  SERVICES
  MARKETING
  TAX
  EQUIPMENT
  SOFTWARE
  RENT
  UTILITIES
}

enum AccountPayableType {
  ONE_TIME
  RECURRING
}

enum AccountPayableStatus {
  PAID
  PENDING
  OVERDUE
  PAID_LATE
  CANCELLED
}

enum NotificationChannel {
  PUSH
  WHATSAPP
}

// ─────────────────────────────────────────────
// Identidade / Autenticação
// ─────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role
  phone        String?
  state        String? // UF autodeclarada no cadastro (não sigiloso, sem criptografia)
  city         String? // cidade autodeclarada no cadastro (não sigiloso, sem criptografia)
  cpfEncrypted Bytes? // AES-256-GCM — nunca em texto plano
  cpfHash      String?    @unique // blind index (HMAC) para busca sem decriptar
  status       UserStatus @default(ACTIVE)
  mfaEnabled   Boolean    @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  familyMember        FamilyMember?
  doctor              Doctor?
  clinicAdminProfile  ClinicAdminProfile?
  employeeProfile     Employee?
  refreshTokens       RefreshToken[]
  caregiverAccesses   CaregiverAccess[]
  auditLogs           AuditLog[]
  notificationPrefs   NotificationPreference[]
  passwordResetTokens PasswordResetToken[]
  pushTokens          PushToken[]
  gmailIntegration    GmailIntegration?

  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  jti         String    @unique
  tokenHash   String
  deviceLabel String? // rótulo aproximado do dispositivo (SO · navegador), derivado do User-Agent no login
  revoked     Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Código de 6 dígitos enviado por e-mail para "esqueci a senha" — nunca persiste
// o código em texto plano (mesmo padrão do MedicalAccessGrant.codeHash).
model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String    @unique
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// Família / Paciente
// ─────────────────────────────────────────────

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           FamilyMember[]
  caregiverAccesses CaregiverAccess[]
  caregiverInvites  CaregiverInvite[]

  @@map("families")
}

model FamilyMember {
  id                String         @id @default(cuid())
  familyId          String
  userId            String?        @unique // null quando o membro não tem login próprio (ex.: menor de idade)
  fullNameEncrypted Bytes
  displayName       String // nome não sigiloso para exibição em listas/avatares
  relationship      String // "Você", "Esposa", "Filho", etc.
  birthDate         DateTime
  biologicalSex     BiologicalSex?
  cpfEncrypted      Bytes?
  cpfHash           String?        @unique
  isAdmin           Boolean        @default(false)
  legalGuardianId   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  family        Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user          User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  healthProfile HealthProfile?
  medications   Medication[]
  vaccines      Vaccine[]
  exams         Exam[]
  diagnostics   Diagnostic[]
  procedures    Procedure[]
  prescriptions Prescription[]
  accessGrants  MedicalAccessGrant[]

  @@index([familyId])
  @@map("family_members")
}

model HealthProfile {
  id             String   @id @default(cuid())
  memberId       String   @unique
  weightKg       Decimal? @db.Decimal(5, 2)
  heightM        Decimal? @db.Decimal(3, 2)
  bloodType      String?
  conditions     String[] // ex.: Hipertensão, Diabetes tipo 2
  allergies      String[] // ex.: Dipirona, Penicilina — crítico
  notesEncrypted Bytes? // observações clínicas livres
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("health_profiles")
}

// ─────────────────────────────────────────────
// Prontuário
// ─────────────────────────────────────────────

enum MedicationSource {
  MANUAL
  DOCTOR
}

model Medication {
  id                       String                @id @default(cuid())
  memberId                 String
  name                     String
  dosage                   String
  dosageUnit               String
  form                     MedicationForm
  stripeColor              MedicationStripeColor @default(NONE)
  frequency                String
  scheduleTimes            String[] // ["08:00", "20:00"]
  weekDays                 String[] // ["seg", "ter", ...] vazio = todos os dias
  specialInstructions      String?
  continuousUse            Boolean               @default(true)
  startDate                DateTime
  endDate                  DateTime?
  stockQuantity            Int?
  lowStockNotifiedAt       DateTime? // evita reenviar push de estoque baixo a cada dose registrada
  prescriptionFileId       String? // referência a objeto no storage (MinIO)
  deactivationReason       String?
  // Preenchido quando o usuário confirma "Entendi, salvar mesmo assim" no aviso de
  // risco (interação/alergia) da checagem por IA — prova durável do aviso ter sido
  // mostrado e reconhecido, independente do AuditLog da checagem em si.
  riskAcknowledgedAt       DateTime?
  /// Chave do cliente pra deduplicar create quando o app recebe NETWORK_ERROR
  /// após o POST já ter gravado (retry do usuário).
  idempotencyKey           String?               @unique
  active                   Boolean               @default(true)
  // Autoria/origem quando a medicação nasce de um receituário (source=DOCTOR) —
  // nulo quando cadastrada manualmente pela família (source=MANUAL, o caminho de sempre).
  doctorId                 String?
  source                   MedicationSource      @default(MANUAL)
  // Vínculo 1:1 com o item de receituário que originou esta medicação — chave de
  // idempotência pra criação automática (Prescription -> Medication) não duplicar.
  sourcePrescriptionItemId String?               @unique
  // Cópia denormalizada de Prescription.linkedDiagnosticId no momento da criação —
  // evita join de 3 saltos (PrescriptionItem->Prescription->Diagnostic) num read-path quente.
  diagnosticId             String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  member                 FamilyMember           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  doctor                 Doctor?                @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  diagnostic             Diagnostic?            @relation(fields: [diagnosticId], references: [id], onDelete: SetNull)
  sourcePrescriptionItem PrescriptionItem?      @relation(fields: [sourcePrescriptionItemId], references: [id], onDelete: SetNull)
  doseRecords            MedicationDoseRecord[]

  @@index([memberId])
  @@index([doctorId])
  @@index([diagnosticId])
  @@map("medications")
}

model MedicationDoseRecord {
  id           String    @id @default(cuid())
  medicationId String
  scheduledAt  DateTime
  takenAt      DateTime?
  state        DoseState
  recordedById String // User.id de quem registrou (paciente, cuidador, etc.)
  createdAt    DateTime  @default(now())

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
  @@index([scheduledAt])
  @@map("medication_dose_records")
}

model Vaccine {
  id                  String        @id @default(cuid())
  memberId            String
  doctorId            String? // autor quando cadastrada por um médico com grant ativo — nulo quando cadastrada pela família
  name                String
  administrationRoute String
  totalDoses          Int
  doseIntervalDays    Int?
  virusType           String?
  status              VaccineStatus @default(UP_TO_DATE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  member FamilyMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  doctor Doctor?       @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  doses  VaccineDose[]

  @@index([memberId])
  @@index([doctorId])
  @@map("vaccines")
}

model VaccineDose {
  id                  String    @id @default(cuid())
  vaccineId           String
  doseNumber          Int
  appliedAt           DateTime
  manufacturer        String
  batchNumber         String? // rastreabilidade — sensível; opcional (nem toda aplicação registra lote)
  location            String
  administrationRoute String
  nextBoosterAt       DateTime?
  createdAt           DateTime  @default(now())

  vaccine Vaccine @relation(fields: [vaccineId], references: [id], onDelete: Cascade)

  @@index([vaccineId])
  @@map("vaccine_doses")
}

model Exam {
  id                    String     @id @default(cuid())
  memberId              String
  doctorId              String? // autor quando enviado por um médico (source=DOCTOR) — nulo em registros antigos/manuais
  name                  String
  examType              ExamType   @default(OUTROS)
  clinicName            String? // nome do laboratório/convênio informado livremente, não uma Clinic cadastrada
  // Nome do médico solicitante do exame — metadado administrativo/atribuição,
  // mesmo tratamento (texto aberto) de clinicName acima, não é narrativa clínica.
  requestingDoctorName  String?
  // Observações livres sobre o exame — texto clínico, sempre cifrado via encryptField().
  observationsEncrypted Bytes?
  examDate              DateTime
  fileId                String? // referência a objeto no storage (MinIO)
  source                ExamSource @default(MANUAL)
  createdAt             DateTime   @default(now())

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  doctor Doctor?      @relation(fields: [doctorId], references: [id])

  @@index([memberId])
  @@index([doctorId])
  @@map("exams")
}

enum ExamType {
  LABORATORIAL
  IMAGEM
  OUTROS
}

model Diagnostic {
  id                   String   @id @default(cuid())
  memberId             String
  doctorId             String?
  title                String
  descriptionEncrypted Bytes
  conductEncrypted     Bytes
  diagnosedAt          DateTime
  createdAt            DateTime @default(now())

  member        FamilyMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  doctor        Doctor?        @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  prescriptions Prescription[]
  medications   Medication[]

  @@index([memberId])
  @@map("diagnostics")
}

enum PrescriptionValidity {
  DAYS_30
  DAYS_60
  DAYS_90
  CONTINUOUS_USE
}

model Prescription {
  id                           String               @id @default(cuid())
  memberId                     String
  doctorId                     String?
  linkedDiagnosticId           String?
  issueDate                    DateTime
  validity                     PrescriptionValidity
  // Observação livre do médico pro receituário como um todo — texto clínico, sempre cifrado.
  generalInstructionsEncrypted Bytes?
  createdAt                    DateTime             @default(now())

  member           FamilyMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  doctor           Doctor?            @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  linkedDiagnostic Diagnostic?        @relation(fields: [linkedDiagnosticId], references: [id], onDelete: SetNull)
  items            PrescriptionItem[]

  @@index([memberId])
  @@index([doctorId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id                    String                @id @default(cuid())
  prescriptionId        String
  name                  String
  dosage                String
  posology              String
  duration              String
  // Instruções específicas do item (ex.: "tomar em jejum") — texto clínico, sempre cifrado.
  instructionsEncrypted Bytes?
  stripeColor           MedicationStripeColor @default(NONE)
  // Campos estruturados abaixo alimentam só a criação automática do Medication
  // (ver Medication.sourcePrescriptionItemId) — dosage/posology/duration acima
  // continuam livres, usados só pra exibição/impressão da receita.
  form                  MedicationForm?
  dosageUnit            String?
  scheduleTimes         String[] // ["08:00", "20:00"]
  weekDays              String[] // ["seg", "ter", ...] vazio = todos os dias
  startDate             DateTime?
  endDate               DateTime?
  continuousUse         Boolean?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medication   Medication?

  @@index([prescriptionId])
  @@map("prescription_items")
}

model Procedure {
  id                          String          @id @default(cuid())
  memberId                    String
  doctorId                    String?
  title                       String
  status                      ProcedureStatus @default(IN_PROGRESS)
  descriptionEncrypted        Bytes?
  // Observações clínicas adicionais — texto sigiloso (LGPD/PHI), sempre cifrado via encryptField().
  observationsEncrypted       Bytes?
  // Motivo do cancelamento/reabertura mais recente — campo único (sobrescrito a
  // cada transição, não é histórico de auditoria), sempre cifrado via encryptField().
  statusChangeReasonEncrypted Bytes?
  performedAt                 DateTime
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  doctor Doctor?      @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@map("procedures")
}

// ─────────────────────────────────────────────
// Autorização de acesso ao prontuário
// (núcleo que conecta app-medcare <-> web-medcare)
// ─────────────────────────────────────────────

model MedicalAccessGrant {
  id                 String         @id @default(cuid())
  memberId           String
  doctorId           String?
  clinicId           String?
  codeHash           String         @unique // código de 6-8 dígitos, nunca salvo em texto plano
  status             AccessStatus   @default(PENDING)
  validity           AccessValidity @default(TEMPORARY)
  temporaryDays      Int? // dias escolhidos (30/60) quando validity=TEMPORARY; null = usa o default do env
  expiresAt          DateTime?
  grantedAt          DateTime?
  revokedAt          DateTime?
  notifiedExpiringAt DateTime? // evita reenviar push de "expirando" todo dia
  lastAccessedAt     DateTime? // última leitura de um módulo clínico via este grant
  createdAt          DateTime       @default(now())

  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  doctor Doctor?      @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  clinic Clinic?      @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([doctorId])
  @@index([status])
  @@map("medical_access_grants")
}

model CaregiverAccess {
  id          String       @id @default(cuid())
  caregiverId String
  familyId    String
  status      AccessStatus @default(PENDING)
  grantedAt   DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime     @default(now())

  caregiver User   @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([caregiverId])
  @@index([familyId])
  @@map("caregiver_accesses")
}

// Convite por e-mail para um cuidador ganhar acesso a uma família — código de
// 6 dígitos enviado por e-mail, resgatado pelo cuidador em (cuidador)/validate-code.
// Mesmo padrão de segurança do PasswordResetToken/MedicalAccessGrant: só o hash
// do código é persistido, nunca o texto plano.
model CaregiverInvite {
  id                 String       @id @default(cuid())
  familyId           String
  email              String
  codeHash           String       @unique
  status             AccessStatus @default(PENDING)
  expiresAt          DateTime
  redeemedAt         DateTime?
  revokedAt          DateTime?
  notifiedExpiringAt DateTime? // evita reenviar push de "expirando" todo dia
  createdAt          DateTime     @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@map("caregiver_invites")
}

// ─────────────────────────────────────────────
// Médicos / Clínicas
// ─────────────────────────────────────────────

model Doctor {
  id          String     @id @default(cuid())
  userId      String     @unique
  crmNumber   String
  crmState    String
  specialties String[]
  planId      String?
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan?                @relation(fields: [planId], references: [id], onDelete: SetNull)
  clinics       ClinicDoctorLink[]
  accessGrants  MedicalAccessGrant[]
  diagnostics   Diagnostic[]
  procedures    Procedure[]
  subscriptions Subscription[]
  exams         Exam[]
  vaccines      Vaccine[]
  prescriptions Prescription[]
  medications   Medication[]

  @@unique([crmNumber, crmState])
  @@index([status])
  @@map("doctors")
}

model Clinic {
  id                 String     @id @default(cuid())
  legalNameEncrypted Bytes
  tradeName          String
  cnpjEncrypted      Bytes
  cnpjHash           String     @unique
  email              String?
  phone              String
  address            Json
  planId             String?
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  plan          Plan?                @relation(fields: [planId], references: [id], onDelete: SetNull)
  doctors       ClinicDoctorLink[]
  admins        ClinicAdminProfile[]
  accessGrants  MedicalAccessGrant[]
  subscriptions Subscription[]

  @@index([status])
  @@map("clinics")
}

model ClinicDoctorLink {
  id       String   @id @default(cuid())
  clinicId String
  doctorId String
  active   Boolean  @default(true)
  linkedAt DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([clinicId, doctorId])
  @@map("clinic_doctor_links")
}

model ClinicAdminProfile {
  id       String @id @default(cuid())
  userId   String @unique
  clinicId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("clinic_admin_profiles")
}

// ─────────────────────────────────────────────
// Planos / Financeiro (admin da plataforma)
// ─────────────────────────────────────────────

model Plan {
  id               String       @id @default(cuid())
  name             String
  type             PlanType
  basePrice        Decimal      @db.Decimal(10, 2)
  billingCycle     BillingCycle @default(MONTHLY)
  // Regras comerciais do plano — só fazem sentido pra type=CLINIC (quantos
  // médicos/dispositivos o preço base já inclui, e o valor cobrado por médico
  // excedente); ficam null em planos type=DOCTOR.
  includedDoctors  Int?
  devicesPerDoctor Int?
  extraMemberFee   Decimal?     @db.Decimal(10, 2)
  status           UserStatus   @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  doctors       Doctor[]
  clinics       Clinic[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                String             @id @default(cuid())
  planId            String
  clinicId          String?
  doctorId          String?
  paymentMethod     PaymentMethod
  billingAddress    Json? // endereço de cobrança — pode divergir do endereço da clínica/médico
  status            SubscriptionStatus @default(ACTIVE)
  nextDueDate       DateTime
  // Só relevante para assinaturas de clínica (Plan.includedDoctors/extraMemberFee) —
  // recalculado automaticamente a cada vínculo/desvínculo de médico, nunca editado
  // diretamente pelo usuário. Valor total cobrado = Plan.basePrice +
  // extraDoctorsCount × Plan.extraMemberFee. Ver clinics.service.ts.
  extraDoctorsCount Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  plan   Plan    @relation(fields: [planId], references: [id], onDelete: Restrict)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor Doctor? @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  payments Payment[]

  @@index([planId])
  @@map("subscriptions")
}

// Cobrança mensal individual de uma assinatura — histórico exibido em "Ver
// histórico de pagamentos" (modal admin de clínicas/financeiro). Gerado de forma
// preguiçosa (lazy) pelo payments.service a partir de Subscription.billingCycle,
// não por um job agendado (não há infraestrutura de scheduler no projeto).
model Payment {
  id             String               @id @default(cuid())
  subscriptionId String
  referenceMonth DateTime // primeiro dia do mês de referência da cobrança
  amountCents    Int
  dueDate        DateTime
  paidAt         DateTime?
  paymentMethod  PaymentMethod
  status         AccountPayableStatus @default(PENDING) // reaproveita o enum já existente (PAID/PENDING/OVERDUE/PAID_LATE/CANCELLED)
  cancelReason   String? // motivo informado ao cancelar a cobrança (status CANCELLED)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, referenceMonth])
  @@index([subscriptionId])
  @@index([status])
  @@map("payments")
}

model Supplier {
  id                String           @id @default(cuid())
  name              String
  documentEncrypted Bytes // CNPJ/CPF — AES-256-GCM, nunca em texto plano
  documentHash      String           @unique // blind index (HMAC) para busca/dedupe sem decriptar
  email             String
  phone             String
  category          SupplierCategory
  status            UserStatus       @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  accountsPayable AccountPayable[]

  @@map("suppliers")
}

model AccountPayable {
  id            String               @id @default(cuid())
  supplierId    String
  description   String
  category      SupplierCategory
  valueCents    Int
  dueDate       DateTime
  paymentMethod PaymentMethod
  type          AccountPayableType   @default(ONE_TIME)
  // Metadados de recorrência (frequência, término) só para exibição/organização —
  // não há job que gera as próximas ocorrências automaticamente (cobrança é manual).
  recurrence    Json?
  status        AccountPayableStatus @default(PENDING)
  paidAt        DateTime?
  receiptFileId String?
  notes         String? // observações registradas ao confirmar o pagamento
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([supplierId])
  @@index([status])
  @@map("accounts_payable")
}

// ─────────────────────────────────────────────
// Notificações
// ─────────────────────────────────────────────

model NotificationPreference {
  id                    String              @id @default(cuid())
  userId                String
  channel               NotificationChannel
  category              String // "medicines" | "medicalRecord" | "family"
  enabled               Boolean             @default(true)
  reminderMinutesBefore Int?                @default(15)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, category])
  @@map("notification_preferences")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

// ─────────────────────────────────────────────
// Snapshots de downloads por loja (App Store Connect / Google Play — Fase 7.2)
// ─────────────────────────────────────────────

model StoreDownloadSnapshot {
  id            String   @id @default(cuid())
  platform      String // "ios" | "android"
  date          DateTime // dia do relatório (granularidade diária)
  downloadCount Int
  source        String // "app_store_connect" | "google_play"
  createdAt     DateTime @default(now())

  @@unique([platform, date, source])
  @@index([platform, date])
  @@map("store_download_snapshots")
}

// ─────────────────────────────────────────────
// Funcionários internos da plataforma (diretório, sem login/auth)
// ─────────────────────────────────────────────

model Employee {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  // Rótulo estático do "perfil de acesso" (ex.: "Administrador", "Suporte") —
  // sem FK real, o sistema de perfis/permissões (ACCESS_PROFILES) continua mockado.
  profileLabel String
  status       UserStatus @default(ACTIVE)
  // Conta de login vinculada (role PLATFORM_ADMIN), criada junto com o funcionário
  // — nullable só pra não quebrar linhas antigas anteriores a essa coluna.
  userId       String?    @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("employees")
}

// E-mails de laboratórios cadastrados pelo admin da plataforma — usados
// futuramente por uma IA para ler resultados/informações enviadas pelos
// laboratórios. Por enquanto só o cadastro (CRUD) existe, sem a leitura.
model LabEmail {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@map("lab_emails")
}

// ─────────────────────────────────────────────
// Auditoria
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String // ex.: "VIEW_MEDICAL_RECORD", "DECRYPT_CPF", "LOGIN"
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// Integração com Gmail (varredura/importação de laudos via GmailImportedExam)
// ─────────────────────────────────────────────

enum GmailIntegrationStatus {
  CONNECTED
  DISCONNECTED
}

model GmailIntegration {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  googleEmail           String
  accessTokenEncrypted  Bytes?
  refreshTokenEncrypted Bytes?
  tokenExpiresAt        DateTime?
  scope                 String
  status                GmailIntegrationStatus @default(CONNECTED)
  autoImportEnabled     Boolean                @default(true)
  importedCount         Int                    @default(0)
  connectedAt           DateTime               @default(now())
  lastVerifiedAt        DateTime               @default(now())
  disconnectedAt        DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailImportedExams GmailImportedExam[]

  @@map("gmail_integrations")
}

enum GmailImportStatus {
  PENDING // aguardando confirmação manual de qual membro é o dono do laudo
  AUTO_LINKED // IA identificou o membro com confiança e já criou o Exam
  IGNORED // IA concluiu que a mensagem não é um laudo (isLabResult=false)
}

// Um registro por mensagem Gmail já processada pelo job de importação — é o
// mecanismo real de dedupe (o filtro after:/before: da busca no Gmail só tem
// granularidade de dia, então é essa @@unique que impede reprocessamento).
model GmailImportedExam {
  id                 String            @id @default(cuid())
  gmailIntegrationId String
  gmailMessageId     String
  suggestedMemberId  String?
  fileId             String? // anexo extraído, guardado via o mesmo fluxo de upload (MinIO)
  extractedSummary   Json // saída estruturada da IA (examType, examDateGuess, resultsSummary, ...)
  status             GmailImportStatus @default(PENDING)
  resolvedExamId     String?
  createdAt          DateTime          @default(now())
  resolvedAt         DateTime?

  gmailIntegration GmailIntegration @relation(fields: [gmailIntegrationId], references: [id], onDelete: Cascade)

  @@unique([gmailIntegrationId, gmailMessageId])
  @@index([status])
  @@map("gmail_imported_exams")
}
